BootStrap: docker
From: condaforge/mambaforge:latest

%post
  # stuff gemini told me to put so that the code runs
  export DEBIAN_FRONTEND=noninteractive
  export TZ=Etc/UTC
  # 1. Update apt and install software-properties-common to get newer gcc
  apt-get update && apt-get install -y git make cmake ninja-build python3-pip wget software-properties-common

  # 2. Add the toolchain repository for modern GCC
  add-apt-repository -y ppa:ubuntu-toolchain-r/test
  apt-get update && apt-get install -y gcc-12 g++-12

  # 3. Symlink the new compilers to the system defaults
  update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-12 100
  update-alternatives --install /usr/bin/g++ g++ /usr/bin/g++-12 100

  # Install Bazelisk (instead of raw bazel)
  # This automatically manages versions via the .bazelversion file
  apt-get install -y wget
  wget https://github.com/bazelbuild/bazelisk/releases/latest/download/bazelisk-linux-amd64 -O /usr/local/bin/bazel
  chmod +x /usr/local/bin/bazel

  # Clone and Build Repositories
  mkdir -p /opt/src
  cd /opt/src
  
  # Clone your repositories
  git clone https://github.com/quantumlib/tesseract-decoder.git
  git clone https://github.com/acatspirit/uf_decoder.git
  git clone https://github.com/seokhyung-lee/ldpc-post-selection.git

  # Build Tesseract
  cd tesseract-decoder
  bazel build //...

  # Build UF-Decoder
  cd /opt/src/uf_decoder
  pip install meson ninja
  meson setup build --buildtype=release
  cd build
  ninja

  # Install Python packages
  cd /opt/src/ldpc-post-selection
  pip install -e .
  cd /opt/src/uf_decoder
  pip install -e .

%environment
  export PATH=/opt/conda/bin:$PATH